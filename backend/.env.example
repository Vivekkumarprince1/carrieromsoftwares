# Legacy template file. Prefer using .env.example
# Development Environment Configuration
MONGO_URI=mongodb://localhost:27017/careers
JWT_SECRET=yourSuperSecretKey

PORT=3000

# JWT Token Configuration - Development (shorter expiry for testing)
JWT_EXPIRES_IN=2h
JWT_COOKIE_EXPIRES_IN=1

# Primary email config (used first)
EMAIL_USER=your-sender@gmail.com
EMAIL_PASS=your_16_char_google_app_password

# Optional SMTP config (for non-Gmail providers)
# MAIL_HOST=smtp.your-provider.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=your_smtp_user
# MAIL_PASS=your_smtp_password
# MAIL_SERVICE=gmail

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Frontend URL Configuration
FRONTEND_URL=https://your-domain.com

# Development flags
NODE_ENV=development

RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe